# AWS
AWS_REGION=us-east-1

# RDS instance (provision script)
RDS_DB_INSTANCE_IDENTIFIER=classicmodels-mysql-g4
RDS_DB_INSTANCE_CLASS=db.t3.micro
RDS_ENGINE=mysql
RDS_ENGINE_VERSION=8.0.40
RDS_ALLOCATED_STORAGE=20
RDS_MASTER_USERNAME=admin
RDS_MASTER_PASSWORD=<STRONG_PASSWORD>
RDS_DB_NAME=classicmodels
RDS_PORT=3306
RDS_PUBLICLY_ACCESSIBLE=true
RDS_MULTI_AZ=false
RDS_BACKUP_RETENTION_PERIOD=0

# Teardown (04_destroy_rds.py)
RDS_SKIP_FINAL_SNAPSHOT=true
RDS_FINAL_SNAPSHOT_IDENTIFIER=

# Security group name (created by 01 if missing; inbound 3306 on default VPC)
EC2_SECURITY_GROUP_NAME=classicmodels-rds-mysql-sg

# SQL dump 
SQL_FILE_PATH=../../data/mysqlsampledatabase.sql

# MySQL client (load + validate); after provision, DB_HOST is set in connection.local.env
#DB_HOST=
DB_USER=admin
DB_PORT=3306
DB_NAME=classicmodels

# Connection retries (RDS may briefly refuse TCP right after "available")
MYSQL_CONNECT_RETRIES=8
MYSQL_CONNECT_DELAY_SECONDS=15
