AWS_REGION=us-east-1
RDS_INSTANCE_IDENTIFIER=fgv-classicmodels
RDS_DB_INSTANCE_CLASS=db.t3.micro
RDS_ALLOCATED_STORAGE=20
RDS_ENGINE=mysql
RDS_ENGINE_VERSION=8.0.35
RDS_MASTER_USERNAME=admin
RDS_MASTER_PASSWORD=change-me
RDS_DB_NAME=classicmodels
RDS_PORT=3306
# Optional: CIDR allowed on RDS security group ingress for MySQL port.
# If empty, provision script auto-detects current public IP and uses /32.
RDS_INGRESS_CIDR=

# Endpoint is discovered after provisioning and reused by load/validate.
# Default local file path for generated endpoint cache in solution_task_1/.
RDS_ENDPOINT=
